# 任选一：整段服务账号 JSON（单行，部署平台常用）
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# 或：服务账号密钥文件路径（本机）
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# 可选：与网页 firebase-config.js 里 COUPLE_REWARDS_PROXY_SECRET 一致
# PROXY_SHARED_SECRET=your-long-random-string

# Gemini（用于生成 NVC / 关键对话 / 笑话）
# GEMINI_API_KEY=your-google-ai-studio-api-key
# 可选：GEMINI_MODEL=gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash

# 本地可 8787；Docker / Railway 默认 8080（与平台 Networking 端口一致）
PORT=8080
